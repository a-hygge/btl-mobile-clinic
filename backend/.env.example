# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://btl_user:btl_password@localhost:5432/btl_healthcare?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_REFRESH_EXPIRES_IN="30d"

# AI Provider (OpenRouter recommended - supports Gemini, GPT, Claude)
AI_PROVIDER="openrouter"
AI_API_KEY="sk-or-v1-your-openrouter-key"
AI_BASE_URL="https://openrouter.ai/api/v1"
AI_MODEL="google/gemini-2.0-flash-001"

# Cloudinary (avatar, prescription images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Payment - VNPAY Sandbox
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3000/api/v1/payments/vnpay/return"

# Payment - Momo Sandbox
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api"

# Email (for OTP / password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Google Maps (for clinic geolocation)
GOOGLE_MAPS_API_KEY=""

# App
APP_URL="http://localhost:3000"
MOBILE_SCHEME="btlhealthcare"
